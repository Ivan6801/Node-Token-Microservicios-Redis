{
  "version": 2,
  "env": {
    "MYSQL_HOST": "remotemysql.com"
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/posts.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/outside",
      "dest": "api/index.js"
    },
    {
      "src": "/api/posts",
      "dest": "api/posts.js"
    }
  ]
}